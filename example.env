# Example environment file (do NOT commit secrets)

TELEGRAM_API_ID=<your_api_id>
TELEGRAM_API_HASH=<your_api_hash>
TELEGRAM_STRING_SESSION=<your_string_session>

# Source channels to listen for deals (comma-separated)
SOURCE_CHANNELS=@TechFactsDeals,@dealbeeofficial,@iamprasadtech,@extrape

# Target channel to post deals to (use chat ID or username)
TARGET_CHANNEL=2999129320

# ExtraPe bot configuration
EXTRAPE_USERNAME=@ExtraPeBot
EXTRAPE_RATE_LIMIT_SECONDS=0.0

TRENDING_MIN_SOURCES=3

REPOST_ENABLED=true
REPOST_AFTER_HOURS=8
REPOST_TRENDING_ONLY=true
